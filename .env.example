# AI Provider Configuration
# Uncomment and set ONE of the following API keys

# OpenAI Configuration
# OPENAI_API_KEY=sk-your-openai-api-key-here
# AI_MODEL=gpt-4o-mini  # Optional: Override default model

# Anthropic Configuration
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# AI_MODEL=claude-3-5-sonnet-20241022  # Optional: Override default model

# Kimi (Moonshot AI) Configuration (推荐，国内访问更稳定)
# MOONSHOT_API_KEY=sk-your-moonshot-api-key-here
# AI_MODEL=moonshot-v1-8k  # Optional: moonshot-v1-8k (8K上下文) or moonshot-v1-32k (32K上下文) or moonshot-v1-128k (128K上下文)

# Provider Selection (optional, defaults to "openai")
# AI_PROVIDER=kimi  # or "openai" or "anthropic"

# Notes:
# 1. Copy this file to .env and add your actual API key
# 2. Only one API key is required (OpenAI, Anthropic, or Kimi)
# 3. The .env file is gitignored for security
# 4. Kimi API 申请地址: https://platform.moonshot.cn/console/api-keys
# 5. Kimi 模型列表:
#    - moonshot-v1-8k: 适合日常对话和简单任务
#    - moonshot-v1-32k: 适合处理较长文本
#    - moonshot-v1-128k: 适合处理超长文本和复杂任务

